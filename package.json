{
  "name": "electrocute-ui",
  "version": "0.1.2",
  "description": "React component library and design system for Electrocute Lab and electrocute.io — design tokens, components, and Storybook docs.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "build-site": "node scripts/build-site.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "storybook": "8.6.14",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "keywords": [
    "design-system",
    "component-library",
    "react",
    "storybook",
    "electrocute"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yafira/electrocute-ui"
  },
  "homepage": "https://electrocute.io"
}
